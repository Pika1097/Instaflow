APP_ENV=development
MONGO_URL=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority
MONGO_DB_NAME=instaflow
SECRET_KEY=change_this_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ENABLE_DEV_ROUTES=false
LOG_LEVEL=INFO
CAMPAIGN_RATE_LIMIT=20
CAMPAIGN_RATE_WINDOW_SECONDS=60
COMMENT_TEST_RATE_LIMIT=30
COMMENT_TEST_RATE_WINDOW_SECONDS=60
